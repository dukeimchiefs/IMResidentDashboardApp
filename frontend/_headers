# Cloudflare merges _headers rules that match the same path rather than
# letting a more specific path replace a less specific one — two matching
# Content-Security-Policy lines are BOTH sent and BOTH enforced by the browser
# (CSP applies the intersection of all policies present). So unlike the simple
# headers below, each distinct CSP variant here is scoped to an explicit,
# non-overlapping path list instead of a shared /* rule + per-path override —
# confirmed against production that the /* + override version silently
# blocked the inline sign-in script on /verify.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

/index.html
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

/style.css
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

